{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "obsidian-cli": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/Storks/obsidian-mcp",
        "obsidian-mcp"
      ],
      "enabled": true,
      "environment": {}
    },
    "electron-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "native-devtools-mcp"
      ],
      "enabled": true,
      "environment": {}
    }
  },
  "permission": {
    "bash": {
      "bun run build": "allow",
      "bun run typecheck": "allow",
      "bun run verify:*": "allow",
      "rtk bun run build": "allow",
      "rtk bun run typecheck": "allow",
      "rtk bun run verify:*": "allow",
      "OBSIDIAN_LAUNCH_MODE=fresh rtk bun run verify:obsidian-real": "allow"
    }
  }
}
