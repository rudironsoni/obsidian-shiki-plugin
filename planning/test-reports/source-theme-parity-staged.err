async function evalStep(cdp,name,expression,timeout=15000){console.log('STEP',name); const result=await Promise.race([cdp.send('Runtime.evaluate',{expression,awaitPromise:true,returnByValue:true}), new Promise((_,reject)=>setTimeout(()=>reject(new Error(`timeout ${name}`)),timeout))]); if(result.exceptionDetails) throw new Error(`${name}: ${result.exceptionDetails.exception?.description||JSON.stringify(result.exceptionDetails)}`); console.log('RESULT',name,JSON.stringify(result.result.value)); return result.result.value;}
