{
  "mcpServers": {
    "obsidian-cli": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "github:Storks/obsidian-mcp"
      ],
      "env": {}
    },
    "electron-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "github:sh3ll3x3c/native-devtools-mcp"
      ],
      "env": {}
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'obsidian-shiki-plugin harness active | Desktop + Mobile emulation | MCPs: obsidian-cli, electron-devtools'"
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "git diff --name-only | grep '\\.ts$' >/dev/null && bun run typecheck || true"
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Executing bash command. Avoid destructive operations on dist/ and exampleVault/'"
          }
        ]
      }
    ]
  }
}
