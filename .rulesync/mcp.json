{
  "$schema": "https://github.com/dyoshikawa/rulesync/releases/latest/download/mcp-schema.json",
  "mcpServers": {
    "obsidian-cli": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "github:Storks/obsidian-mcp"
      ],
      "env": {}
    },
    "electron-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "github:sh3ll3x3c/native-devtools-mcp"
      ],
      "env": {}
    }
  }
}
