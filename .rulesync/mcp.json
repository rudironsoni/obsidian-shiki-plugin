{
  "$schema": "https://github.com/dyoshikawa/rulesync/releases/latest/download/mcp-schema.json",
  "mcpServers": {
    "obsidian-cli": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "github:Storks/obsidian-mcp"
      ],
      "env": {}
    },
		"electron-devtools": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"native-devtools-mcp"
			],
			"env": {}
		}
	}
}
