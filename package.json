{
	"name": "shiki-highlighter",
	"version": "0.8.0-beta.186",
	"description": "Highlight code blocks with Shiki.",
	"main": "main.js",
	"scripts": {
		"dev": "vite build --mode=development --watch",
		"clean:dist": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
		"build": "bun run clean:dist && SHIKI_BUILD_ENTRY=modern-monaco vite build --mode=production && node scripts/inline-modern-monaco.mjs && bun run typecheck && SHIKI_BUILD_ENTRY=main vite build --mode=production && node scripts/embed-modern-monaco-fallback.mjs",
		"typecheck": "tsc -noEmit -skipLibCheck",
		"test": "bun test",
		"test:log": "LOG_TESTS=true bun test",
		"bench:startup": "node tests/performance/startup-bench.mjs",
		"bench:startup:mobile": "OBSIDIAN_EMULATE_MOBILE=true node tests/performance/startup-bench.mjs",
		"verify:obsidian-real": "node tests/runtime/obsidian-real.mjs",
		"verify:obsidian-monaco-edit": "node tests/runtime/obsidian-monaco-edit.mjs",
		"verify:obsidian-live-preview-interactions": "node tests/runtime/obsidian-live-preview-interactions.mjs",
		"verify:obsidian-live-preview-redraw-loop": "node tests/runtime/obsidian-live-preview-redraw-loop.mjs",
		"verify:obsidian-monaco-mobile-rendering": "node tests/runtime/obsidian-monaco-mobile-rendering.mjs",
		"verify:obsidian-monaco-scroll-flicker": "node tests/runtime/obsidian-monaco-mobile-rendering.mjs",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "eslint --max-warnings=0 packages/**",
		"lint:fix": "eslint --max-warnings=0 --fix packages/**",
		"check": "bun run format:check && bun run build && bun run lint && bun run test && bun run bench:startup && bun run bench:startup:mobile",
		"check:fix": "bun run format && bun run typecheck && bun run lint:fix && bun run test",
		"release": "lemons-automation release"
	},
	"keywords": [],
	"author": "Moritz Jung",
	"license": "MIT",
	"devDependencies": {
		"@codemirror/language": "^6.12.3",
		"@codemirror/state": "^6.6.0",
		"@codemirror/view": "^6.41.1",
		"@eslint/js": "^9.39.4",
		"@happy-dom/global-registrator": "^20.10.6",
		"@lemons_dev/lemons-obsidian-plugin-automation": "^0.1.3",
		"@lezer/common": "^1.5.2",
		"@tsconfig/svelte": "^5.0.8",
		"@types/bun": "^1.3.13",
		"@types/prismjs": "^1.26.6",
		"eslint-plugin-import-x": "^4.16.2",
		"eslint-plugin-no-relative-import-paths": "^1.6.1",
		"obsidian": "latest",
		"prettier": "^3.8.3",
		"shiki": "^3.23.0",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.0",
		"vite": "^8.0.10",
		"vite-plugin-banner": "^0.8.1",
		"vite-plugin-static-copy": "^4.1.0"
	},
	"dependencies": {
		"modern-monaco": "^0.4.2"
	}
}
